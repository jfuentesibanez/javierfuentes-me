# Copia este archivo a .env.local para desarrollo local (con `vercel dev`).
# En produccion, define estas variables en el panel de Vercel (Settings -> Environment Variables).
# NUNCA subas el .env real al repo.

# Clave de la API de Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Modelo del bot (opcional). Por defecto: claude-haiku-4-5
# Alternativas: claude-sonnet-4-6 (mas capaz, mas caro), claude-opus-4-8 (top, mas caro aun)
BOT_MODEL=claude-haiku-4-5
